# ═══════════════════════════════════════════════════════
# ant-ling Chat API — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env .env.local   (then edit .env.local)

# ── Upstream server ──────────────────────────────
# Set to the real server to enable proxy mode.
# Leave unset or empty for standalone/mock mode.
ANTLING_BASE_URL=https://chat.ant-ling.com

# ── Authentication ───────────────────────────────
# The real chat.ant-ling.com API uses TWO auth mechanisms:
#
# 1. Cookie-based session (primary):
#    - TLingSESSIONID  — JWT session token issued after login
#    - jsh_t_c_e       — tracking/analytics cookie
#    - spanner         — infrastructure routing cookie
#
#    To get these: open chat.ant-ling.com in your browser,
#    log in, then open DevTools > Network tab > any request >
#    copy the "Cookie" header value.
#
#    Example value (paste the FULL cookie string):
ANTLING_SESSION_COOKIE=TLingSESSIONID=eyJhbGciOiJIUzI1NABCDEFGHIJKLMNOPQRSTUVWXYZ.xxxx; jsh_t_c_e=jsh_t_0.xxxx; spanner=xxxx

# 2. Tenant ID header (required on every request):
ANTLING_TENANT_ID=20260523LTJABC12312WC

# ── Local API key (optional) ────────────────────
# Key for local proxy authentication (not used by the real API).
# Set this if you want to require a key for clients connecting
# to your local server.
ANTLING_API_KEY=sk-no-key-required

# ── Server ───────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Adapter keys ────────────────────────────────
# Keys accepted by the OpenAI/Anthropic adapter endpoints.
OPENAI_API_KEY=sk-no-key-required
ANTHROPIC_API_KEY=sk-no-key-required
